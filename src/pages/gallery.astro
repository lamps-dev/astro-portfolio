---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { resolveGroups, pageTransform } from '../lib/gallery';

const groups = await resolveGroups();
const hasImages = groups.some((g) => g.items.length > 0);
---

<BaseLayout
  title="Gallery"
  description="A collection of photos and renders, sorted into folders. Open a folder to browse it."
>
  <div class="gallery-view" transition:name="gallery-view" transition:animate={pageTransform}>
    <SectionHeading level="h1" eyebrow="gallery">Things I've shot & made</SectionHeading>
    <p class="lede">
      Sorted into folders. Hover a folder to peek inside, then click to open it.
    </p>

    {hasImages ? (
      <div class="folders">
        {groups.map((group) => (
          <a class="folder-card" href={`/gallery/${group.slug}`} aria-label={`Open ${group.title}`}>
            <span class="folder" aria-hidden="true">
              <span class="folder__tab"></span>
              <span class="folder__back"></span>
              {group.items[0] && (
                <Image src={group.items[0].image} alt="" widths={[220]} sizes="110px" class="paper paper--left" />
              )}
              {group.items[1] && (
                <Image src={group.items[1].image} alt="" widths={[220]} sizes="110px" class="paper paper--right" />
              )}
              <span class="folder__front"></span>
            </span>
            <span class="folder-label">
              <span class="folder-title">{group.title}</span>
              <span class="folder-count">{group.items.length} photo{group.items.length === 1 ? '' : 's'}</span>
            </span>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty">
        <span class="empty-icon">∅</span>
        <span>No images yet. Add some to <code>src/data/gallery.ts</code>.</span>
      </div>
    )}
  </div>
</BaseLayout>

<style is:global>
  /* Full-page transform used when opening/closing a folder. */
  @keyframes gallery-in {
    from { opacity: 0; transform: translateY(18px) scale(0.98); }
    to { opacity: 1; transform: none; }
  }
  @keyframes gallery-out {
    from { opacity: 1; transform: none; }
    to { opacity: 0; transform: translateY(-12px) scale(0.99); }
  }
</style>

<style>
  .lede {
    color: var(--color-muted);
    margin: -0.5rem 0 2rem;
  }

  .folders {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
  }

  .folder-card {
    --folder-back: color-mix(in oklab, var(--color-accent) 70%, #6b5a2e);
    --folder-front: color-mix(in oklab, var(--color-accent) 85%, #d8b24a);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    padding: 0.75rem;
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
  }
  .folder-card.bounce {
    animation: folder-bounce 0.42s cubic-bezier(0.28, 0.84, 0.42, 1);
  }
  @keyframes folder-bounce {
    0% { transform: scale(1); }
    30% { transform: scale(0.94); }
    55% { transform: scale(1.04); }
    75% { transform: scale(0.99); }
    100% { transform: scale(1); }
  }

  /* Folder body */
  .folder {
    position: relative;
    width: 132px;
    height: 100px;
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .folder__tab {
    position: absolute;
    top: -11px;
    left: 12px;
    width: 50px;
    height: 16px;
    border-radius: 8px 8px 0 0;
    background: var(--folder-back);
  }
  .folder__back {
    position: absolute;
    inset: 0;
    border-radius: 4px 12px 12px 12px;
    background: var(--folder-back);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }
  /* Photos tucked inside — hidden behind the front until hover. */
  .paper {
    position: absolute;
    left: 50%;
    bottom: 9px;
    z-index: 1;
    width: 66%;
    height: 72%;
    object-fit: cover;
    border-radius: 4px;
    background: #fff;
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.28);
    transform: translateX(-50%) translateY(2px);
    transition: transform 0.4s cubic-bezier(0.2, 0.85, 0.3, 1);
  }
  /* Front pocket, sits above the photos. */
  .folder__front {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    width: 100%;
    height: 88%;
    border-radius: 4px 12px 12px 12px;
    background: linear-gradient(
      160deg,
      var(--folder-front),
      color-mix(in oklab, var(--folder-front) 80%, #000)
    );
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transform-origin: bottom center;
    transition: transform 0.4s cubic-bezier(0.2, 0.85, 0.3, 1);
  }

  /* Hover: lift folder, open the front, slide the two photos out. */
  .folder-card:hover .folder,
  .folder-card:focus-visible .folder {
    transform: translateY(-6px);
  }
  .folder-card:hover .folder__front,
  .folder-card:focus-visible .folder__front {
    transform: skewX(7deg) scaleY(0.55) translateY(2px);
  }
  .folder-card:hover .paper--left,
  .folder-card:focus-visible .paper--left {
    transform: translate(-118%, -54%) rotate(-16deg);
  }
  .folder-card:hover .paper--right,
  .folder-card:focus-visible .paper--right {
    transform: translate(18%, -54%) rotate(16deg);
  }

  .folder-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .folder-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .folder-count {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .empty {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 10px;
    color: var(--color-muted);
    font-style: italic;
  }
  .empty-icon {
    font-family: var(--font-mono);
    font-size: 1.1rem;
  }
  .empty code {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.85em;
  }

  @media (prefers-reduced-motion: reduce) {
    .folder,
    .folder__front,
    .paper {
      transition: none;
    }
    .folder-card.bounce {
      animation: none;
    }
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';

  // Bounce the folder on click, then transition to its page. Runs on first
  // load and after every client-side navigation (astro:page-load).
  function setupFolders() {
    document.querySelectorAll<HTMLAnchorElement>('.folder-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        // Let modified clicks (new tab, etc.) behave normally.
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        const href = card.getAttribute('href');
        if (!href) return;
        e.preventDefault();

        // Replay the bounce, then navigate once it has had a moment to play.
        card.classList.remove('bounce');
        void card.offsetWidth; // force reflow so the animation restarts
        card.classList.add('bounce');
        window.setTimeout(() => navigate(href), 190);
      });
    });
  }

  document.addEventListener('astro:page-load', setupFolders);
</script>
