---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects, type ProjectStatus } from '../data/projects';

const sections: { id: string; title: string; status: ProjectStatus; blurb: string }[] = [
  {
    id: 'works',
    title: 'stuff that works',
    status: 'active',
    blurb: 'Things I actively maintain or am building right now.',
  },
  {
    id: 'silly',
    title: 'Random and Silly',
    status: 'random and silly',
    blurb: 'Jokes, dares, vibecoded one-off nonsense.',
  },
  {
    id: 'rip',
    title: 'Old and abandonned, rip',
    status: 'old and abandonned, rip',
    blurb: 'Old, broken, abandoned. left as-is for the museum.',
  },
  {
    id: 'nolongeractive',
    title: 'No longer active',
    status: 'no longer active',
    blurb: 'No longer active, no commits for a while.',
  },
  {
    id: 'wip',
    title: 'WIP',
    status: 'wip',
    blurb: 'WIP.',
  },
  {
    id: 'semiactive',
    title: 'Semi-active',
    status: 'semi-active',
    blurb: 'Semi-active.'
  }
];

const grouped = sections.map((s) => ({
  ...s,
  items: projects.filter((p) => p.status === s.status),
}));
---

<BaseLayout
  title="projects"
  description="everything i've made, sorted into things that work, things that are dumb, and rip."
>
  <SectionHeading level="h1" eyebrow="projects">Things i've made</SectionHeading>
  <p class="lede">
    Sorted into the three states of code: working, silly, dead, semi-active, wip, no longer active.
  </p>

  <nav class="jumps" aria-label="section jumps">
    {grouped.map((s) => (
      <a href={`#${s.id}`} class={`jump status-${s.status}`}>
        <span class="jump-title">{s.title}</span>
        <span class="jump-count">{s.items.length}</span>
      </a>
    ))}
  </nav>

  {grouped.map((s) => (
    <section class={`group status-${s.status}`} id={s.id}>
      <div class="group-head">
        <SectionHeading eyebrow={`section`}>
          {s.title}
          <span class="count">{s.items.length}</span>
        </SectionHeading>
      </div>
      <p class="blurb">{s.blurb}</p>
      {s.items.length > 0 ? (
        <div class="grid">
          {s.items.map((p) => <ProjectCard project={p} />)}
        </div>
      ) : (
        <div class="empty">
          <span class="empty-icon">∅</span>
          <span>nothing here yet.</span>
        </div>
      )}
    </section>
  ))}
</BaseLayout>

<style>
  .lede {
    color: var(--color-muted);
    margin: -0.5rem 0 1.25rem;
  }
  .jumps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .jump {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--color-text);
    background: color-mix(in oklab, var(--color-bg) 92%, var(--color-border));
    transition: border-color 0.2s, transform 0.2s;
  }
  .jump:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .jump-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .jump-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-border) 70%, transparent);
    color: var(--color-muted);
  }
  .jump.status-active .jump-count {
    background: color-mix(in oklab, var(--color-accent) 25%, transparent);
    color: var(--color-accent);
  }
  .jump.status-stupid {
    border-style: dashed;
  }
  .jump.status-rip {
    opacity: 0.7;
  }

  .blurb {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: -0.5rem 0 1rem;
  }
  .group {
    margin-bottom: 2.5rem;
    scroll-margin-top: 5rem;
  }
  .group-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .count {
    display: inline-block;
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    padding: 0.1rem 0.55rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-border) 70%, transparent);
    vertical-align: middle;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .empty {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: 10px;
    color: var(--color-muted);
    font-style: italic;
  }
  .empty-icon {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--color-muted);
  }
</style>
