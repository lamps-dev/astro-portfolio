---
import SocialLinks from './SocialLinks.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="row">
    <p class="copy">&copy; {year} lamp. Rewritten and built with Astro.</p>
    <SocialLinks size={18} />
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    padding: 1.5rem 1.25rem;
  }
  .row {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .copy {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }
</style>
