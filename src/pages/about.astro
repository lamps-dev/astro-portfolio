---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { Icon } from 'astro-icon/components';

const facts = [
  { label: 'age', value: '13' },
  { label: 'where', value: 'montpellier, fr' },
  { label: 'main', value: 'python / c#' },
  { label: 'cat', value: 'salma' },
];

const domains = [
  { href: 'https://lamps-dev.dev', name: 'lamps-dev.dev', detail: 'this site', external: false },
  { href: 'https://onlycats.info', name: 'onlycats.info', detail: 'a joke project', external: true },
  { href: 'https://sillycat.cloud', name: 'sillycat.cloud', detail: 'in progress', external: true },
  { href: null, name: 'uniqueweb.site', detail: 'parked, nothing yet', external: false },
];
---

<BaseLayout
  title="about"
  description="about lamp. 13, montpellier, codes things."
>
  <SectionHeading level="h1" eyebrow="about">hi, i'm lamp</SectionHeading>

  <div class="facts">
    {facts.map((f) => (
      <div class="fact">
        <span class="fact-label">{f.label}</span>
        <span class="fact-value">{f.value}</span>
      </div>
    ))}
  </div>

  <div class="prose">
    <p>
      I'm 13 and I live in REDACTED, France. I mostly code in Python, React and
      C#, but i'll use whatever the project needs (JS, HTML, CSS, Lua,
      Powershell, Bash, React, and more).
    </p>

    <p>
      I code stuff and I'm also a <a href="https://youtube.com/@ilovelampadaire" target="_blank" rel="noopener noreferrer">YouTuber</a> (Note: The username is my old cringy one I won't chane cuz I need to change it everywhere afterwards).
      I have around 300 subs. I also have a black tortoiseshell cat named Salma (A bit shy to me still but a bit less shy than usual).
      I self-host a bunch of services and small websites cuz I like coding and self-hosting.
    </p>
  </div>

  <SectionHeading level="h3" eyebrow="domains">Things i own</SectionHeading>
  <ul class="domains">
    {domains.map((d) => (
      <li class={d.href ? '' : 'parked'}>
        {d.href ? (
          <a href={d.href} target={d.external ? '_blank' : undefined} rel={d.external ? 'noopener noreferrer' : undefined}>
            <span class="domain-name">{d.name}</span>
            <span class="domain-detail">{d.detail}</span>
            <Icon name={d.external ? 'lucide:external-link' : 'lucide:arrow-right'} class="domain-icon" width={14} height={14} />
          </a>
        ): (
        <p></p>
        )}
      </li>
    ))}
  </ul>

  <SectionHeading level="h3" eyebrow="elsewhere">find me</SectionHeading>
  <ul class="contacts">
    <li>
      <Icon name="lucide:github" width={16} height={16} />
      <a href="https://github.com/lamps-dev" target="_blank" rel="noopener noreferrer">lamps-dev</a>
      <span class="muted">GitHub</span>
    </li>
    <li>
      <Icon name="lucide:at-sign" width={16} height={16} />
      <a href="https://mastodon.social/@lampyt" target="_blank" rel="noopener noreferrer">@lampyt@mastodon.social</a>
      <span class="muted">Mastodon</span>
    </li>
    <li>
      <Icon name="lucide:message-circle" width={16} height={16} />
      <span>lampyt</span>
      <span class="muted">Disord username</span>
    </li>
  </ul>

  <p class="outro">
    That's pretty much it. Check out <a href="/projects">projects</a> if you
    want to see what I've been making, or <a href="/now">now</a> If you want
    to know what i'm up to right this second.
  </p>
</BaseLayout>

<style>
  .facts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.5rem;
    margin: 0.5rem 0 2rem;
  }
  .fact {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: color-mix(in oklab, var(--color-bg) 90%, var(--color-border));
    transition: border-color 0.2s, transform 0.2s;
  }
  .fact:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .fact-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
  .fact-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .prose {
    font-size: 1rem;
    line-height: 1.7;
  }
  .prose p {
    margin: 0 0 1.1em;
  }

  .domains {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .domains li a,
  .parked-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    text-decoration: none;
    background: color-mix(in oklab, var(--color-bg) 92%, var(--color-border));
    transition: border-color 0.2s, transform 0.2s, background-color 0.2s;
  }
  .domains li a:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
    background: color-mix(in oklab, var(--color-bg) 80%, var(--color-accent));
  }
  .domains li.parked .parked-row {
    opacity: 0.55;
    border-style: dashed;
  }
  .domain-name {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .domain-detail {
    flex: 1;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .domain-icon {
    color: var(--color-muted);
    transition: transform 0.2s, color 0.2s;
  }
  .domains li a:hover .domain-icon {
    color: var(--color-accent);
    transform: translateX(2px);
  }

  .contacts {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .contacts li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
  }
  .contacts li :global(svg) {
    color: var(--color-muted);
    flex-shrink: 0;
  }
  .contacts .muted {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .outro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-top: 2rem;
  }
</style>
