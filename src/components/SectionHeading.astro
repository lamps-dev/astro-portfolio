---
interface Props {
  id?: string;
  eyebrow?: string;
  level?: 'h1' | 'h2' | 'h3';
  class?: string;
}

const { id, eyebrow, level = 'h2', class: className = '' } = Astro.props;
const Tag = level;
---

<div class={`section-heading ${className}`} id={id}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <Tag class="title"><slot /></Tag>
</div>

<style>
  .section-heading {
    margin: 2.5rem 0 1.25rem;
  }
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
  }
  .title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  h1.title {
    font-size: 2.25rem;
  }
  h3.title {
    font-size: 1.15rem;
  }
</style>
