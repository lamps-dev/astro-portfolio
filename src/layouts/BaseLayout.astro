---
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MusicPlayer from '../components/MusicPlayer.tsx';

interface Props {
  title: string;
  description: string;
  image?: string;
  /** When true, page content is rendered without the centered .page wrapper. */
  fullBleed?: boolean;
  /** Hide the floating music player (e.g. on 404). */
  hideMusic?: boolean;
}

const { title, description, image, fullBleed = false, hideMusic = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <ClientRouter />
  </head>
  <body>
    <Navbar />
    <main class={fullBleed ? '' : 'page'}>
      <slot />
    </main>
    <Footer />
    {!hideMusic && <MusicPlayer client:load transition:persist />}
  </body>
</html>
