---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, date, updated, tags } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-head">
      <p class="kicker">
        <a href="/blog">&larr; all posts</a>
      </p>
      <h1>{title}</h1>
      <p class="meta">
        <FormattedDate date={date} />
        {updated && (
          <>
            {' '}<span class="dot">&middot;</span>{' '}
            <span>updated <FormattedDate date={updated} /></span>
          </>
        )}
      </p>
      {tags && tags.length > 0 && (
        <ul class="tags">
          {tags.map((t) => <li>#{t}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <section class="comments" aria-label="comments">
      <h2 class="comments-heading">comments</h2>
      <div class="giscus-container" id="giscus-container"></div>
    </section>
  </article>
</BaseLayout>

<style>
  .post-head {
    margin-bottom: 2rem;
  }
  .kicker {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .post-head h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .meta {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin: 0;
  }
  .dot { opacity: 0.6; }
  .tags {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
  }
  .prose {
    font-size: 1rem;
    line-height: 1.7;
  }
  .prose :global(h2) {
    font-size: 1.4rem;
    margin: 2rem 0 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.15rem;
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1.1em;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4em;
    margin: 0 0 1.1em;
  }
  .prose :global(img) {
    border-radius: 8px;
    margin: 1em 0;
  }
  .comments {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .comments-heading {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }
</style>

<!--
  Giscus must be re-injected on every client-side navigation: the
  static <script src=...> only runs once, and ClientRouter doesn't
  re-execute it. Listen on astro:page-load (fires on initial load AND
  every navigation) and rebuild the iframe each time.
-->
<script is:inline>
  (function () {
    const GISCUS_ATTRS = {
      src: 'https://giscus.app/client.js',
      'data-repo': 'lamps-dev/astro-portfolio',
      'data-repo-id': 'R_kgDOSQNYOg',
      'data-category': 'General',
      'data-category-id': 'DIC_kwDOSQNYOs4C8HiP',
      'data-mapping': 'url',
      'data-strict': '0',
      'data-reactions-enabled': '1',
      'data-emit-metadata': '0',
      'data-input-position': 'bottom',
      'data-theme': 'preferred_color_scheme',
      'data-lang': 'en',
      crossorigin: 'anonymous',
    };

    function mount() {
      const container = document.getElementById('giscus-container');
      if (!container) return;
      // Clear any previous iframe / script so giscus re-binds to the
      // current URL via data-mapping="url".
      container.replaceChildren();
      const s = document.createElement('script');
      for (const [k, v] of Object.entries(GISCUS_ATTRS)) s.setAttribute(k, v);
      s.async = true;
      container.appendChild(s);
    }

    document.addEventListener('astro:page-load', mount);
  })();
</script>