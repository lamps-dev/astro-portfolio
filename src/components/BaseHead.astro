---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = '/og-default.png' } = Astro.props;
const fullTitle = title === SITE_TITLE ? title : `${title} - ${SITE_TITLE}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
{/* Functional-storage consent gate. Theme/personalization is persisted in
    localStorage only when the "Functional" category is enabled. It's on by
    default, so theme is remembered until a visitor explicitly turns Functional
    off in the privacy banner. Reads the decision straight from storage so it
    works before /lampconsent.js has loaded. No decision yet → default on. */}
<script is:inline>
  window.__functionalConsent = function () {
    try {
      const raw = localStorage.getItem('lamp_consent');
      if (!raw) return true;
      const data = JSON.parse(raw);
      return !!(data && data.prefs && data.prefs.Functional);
    } catch (e) { return true; }
  };
</script>

{/* Anti-flash theme: runs synchronously before paint, and before
    /lampconsent.js so the theme class is applied without a flash. */}
<script is:inline>
  (() => {
    const canStore = window.__functionalConsent();
    let stored = null;
    try { if (canStore) stored = localStorage.getItem('theme'); } catch {}
    const theme = stored === 'light' ? 'light' : 'dark';
    if (theme === 'dark') document.documentElement.classList.add('dark');
    else document.documentElement.classList.remove('dark');
    try {
      if (canStore) localStorage.setItem('theme', theme);
      else localStorage.removeItem('theme');
    } catch {}
  })();
</script>

<script is:inline>
  document.addEventListener('astro:after-swap', () => {
    const stored = window.__functionalConsent() ? localStorage.getItem('theme') : null;
    const theme = stored === 'light' ? 'light' : 'dark';
    if (theme === 'dark') document.documentElement.classList.add('dark');
    else document.documentElement.classList.remove('dark');
  });
</script>

<script is:inline>
  document.addEventListener('storage', (e) => {
    if (e.key === 'theme' && e.newValue) {
      if (e.newValue === 'dark') document.documentElement.classList.add('dark');
      else document.documentElement.classList.remove('dark');
    }
  });
</script>

<!-- LampConsent (cookie consent). Inits Google Consent Mode defaults; the tags
     below stay blocked until the matching category is opted in. -->
<script is:inline src="/lampconsent.js"></script>
<script is:inline>
  LampConsent.init({
    position: 'bottom-center',
    theme: 'auto',
    accentColor: '#c4b5fd',
    accentTextColor: '#2e1065',
    texts: {
      title: 'We value your privacy',
      description: 'We use cookies for analytics, and to improve your experience. You can accept everything or pick what you want.',
      acceptAll: 'Accept all',
      rejectAll: 'Reject all',
      manage: 'Manage',
      modalTitle: 'Privacy Settings',
      modalDescription: 'Pick which cookies you want to allow. You can change this anytime.',
      save: 'Save preferences',
      cancel: 'Cancel',
      floatingLabel: 'Privacy',
      policyLink: '/privacy',
    },
    categories: [
      { id: 'Necessary', name: 'Strictly necessary', desc: 'Required for the site to work properly.', required: true, gtag: [] },
      { id: 'Functional', name: 'Functional', desc: 'Remembers your preferences like theme and language.', required: false, default: true, gtag: ['functionality_storage', 'personalization_storage'] },
      { id: 'Analytics', name: 'Analytics', desc: 'Helps us understand how visitors use the site.', required: false, gtag: ['analytics_storage'] },
    ],
    onChange: function (prefs) {
      // Turning Functional off stops the site from remembering your theme.
      if (!prefs.Functional) { try { localStorage.removeItem('theme'); } catch (e) {} }
    },
  });
</script>

<!-- Google Tag Manager — blocked until Analytics consent is granted -->
<script type="text/plain" data-lamp-category="Analytics" data-lamp-vendor="google_tag_manager" is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-5QT8BRFL');</script>
<!-- End Google Tag Manager -->
<!-- Google tag (gtag.js) — blocked until Analytics consent is granted -->
<script type="text/plain" data-lamp-category="Analytics" is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-VN2SEP839X"></script>
<script type="text/plain" data-lamp-category="Analytics" is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-VN2SEP839X');
</script>

<!-- Cloudflare Web Analytics — blocked until Analytics consent is granted -->
<script type="text/plain" data-lamp-category="Analytics" is:inline defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "4271c7e69a684ce199c6bef2e752d79e"}'></script>
<!-- End Cloudflare Web Analytics -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />
