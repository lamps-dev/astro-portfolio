---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, date, updated, tags } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-head">
      <p class="kicker">
        <a href="/blog">&larr; all posts</a>
      </p>
      <h1>{title}</h1>
      <p class="meta">
        <FormattedDate date={date} />
        {updated && (
          <>
            {' '}<span class="dot">&middot;</span>{' '}
            <span>updated <FormattedDate date={updated} /></span>
          </>
        )}
      </p>
      {tags && tags.length > 0 && (
        <ul class="tags">
          {tags.map((t) => <li>#{t}</li>)}
        </ul>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <section class="comments" aria-label="comments">
      <h2 class="comments-heading">comments</h2>
      <div class="giscus-container" id="giscus-container"></div>
    </section>
  </article>

  <!-- Lightbox overlay, hidden until a post image is clicked. -->
  <div class="lightbox" id="blog-lightbox" hidden aria-hidden="true">
    <div class="lightbox-backdrop" data-close></div>
    <figure class="lightbox-figure">
      <button type="button" class="lightbox-close" data-close aria-label="Close">&times;</button>
      <img class="lightbox-img" id="blog-lightbox-img" src="" alt="" />
      <figcaption class="lightbox-caption" id="blog-lightbox-caption"></figcaption>
    </figure>
  </div>
</BaseLayout>

<style>
  .post-head {
    margin-bottom: 2rem;
  }
  .kicker {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .post-head h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .meta {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin: 0;
  }
  .dot { opacity: 0.6; }
  .tags {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
  }
  .prose {
    font-size: 1rem;
    line-height: 1.7;
  }
  .prose :global(h2) {
    font-size: 1.4rem;
    margin: 2rem 0 0.75rem;
  }
  .prose :global(h3) {
    font-size: 1.15rem;
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1.1em;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.4em;
    margin: 0 0 1.1em;
  }
  .prose :global(img) {
    border-radius: 8px;
    margin: 1em 0;
    max-width: 100%;
    height: auto;
    cursor: zoom-in;
    transition: opacity 0.2s;
  }
  .prose :global(img:hover) {
    opacity: 0.9;
  }

  /* ---- Lightbox (mirrors the gallery lightbox) ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklab, #000 78%, transparent);
    backdrop-filter: blur(4px);
    cursor: zoom-out;
  }
  .lightbox-figure {
    position: relative;
    margin: 0;
    max-width: min(1100px, 100%);
    max-height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    animation: lightbox-in 0.18s ease-out;
  }
  @keyframes lightbox-in {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }
  .lightbox-img {
    display: block;
    max-width: 100%;
    max-height: 80vh;
    width: auto;
    height: auto;
    margin: 0 auto;
    border-radius: 10px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }
  .lightbox-close {
    position: absolute;
    top: -0.75rem;
    right: -0.75rem;
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s;
  }
  .lightbox-close:hover {
    border-color: var(--color-accent);
    transform: scale(1.05);
  }
  .lightbox-caption {
    text-align: center;
    font-size: 0.9rem;
    line-height: 1.5;
    color: color-mix(in oklab, #fff 80%, transparent);
  }
  .lightbox-caption:empty {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox-figure,
    .lightbox-close {
      transition: none;
      animation: none;
    }
  }
  .comments {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .comments-heading {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 1rem;
    letter-spacing: -0.01em;
  }
</style>

<!--
  Giscus must be re-injected on every client-side navigation: the
  static <script src=...> only runs once, and ClientRouter doesn't
  re-execute it. Listen on astro:page-load (fires on initial load AND
  every navigation) and rebuild the iframe each time.
-->
<script is:inline>
  (function () {
    const GISCUS_ATTRS = {
      src: 'https://giscus.app/client.js',
      'data-repo': 'lamps-dev/astro-portfolio',
      'data-repo-id': 'R_kgDOSQNYOg',
      'data-category': 'General',
      'data-category-id': 'DIC_kwDOSQNYOs4C8HiP',
      'data-mapping': 'url',
      'data-strict': '0',
      'data-reactions-enabled': '1',
      'data-emit-metadata': '0',
      'data-input-position': 'bottom',
      'data-theme': 'preferred_color_scheme',
      'data-lang': 'en',
      crossorigin: 'anonymous',
    };

    function mount() {
      const container = document.getElementById('giscus-container');
      if (!container) return;
      // Clear any previous iframe / script so giscus re-binds to the
      // current URL via data-mapping="url".
      container.replaceChildren();
      const s = document.createElement('script');
      for (const [k, v] of Object.entries(GISCUS_ATTRS)) s.setAttribute(k, v);
      s.async = true;
      container.appendChild(s);
    }

    document.addEventListener('astro:page-load', mount);
  })();
</script>

<!--
  Make every image inside a post clickable: opens a fullscreen lightbox
  with a blurred backdrop and the image's alt text shown as a caption at
  the bottom. Bound on astro:page-load so it works on first load AND after
  every client-side navigation.
-->
<script>
  function setupBlogLightbox() {
    const lightbox = document.getElementById('blog-lightbox');
    if (!lightbox) return;

    const img = document.getElementById('blog-lightbox-img') as HTMLImageElement | null;
    const captionEl = document.getElementById('blog-lightbox-caption');
    if (!img || !captionEl) return;

    function open(full: string, alt: string) {
      img!.src = full;
      img!.alt = alt;
      captionEl!.textContent = alt;
      lightbox!.hidden = false;
      lightbox!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lightbox!.hidden = true;
      lightbox!.setAttribute('aria-hidden', 'true');
      img!.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLImageElement>('.prose img').forEach((el) => {
      el.addEventListener('click', () => {
        open(el.currentSrc || el.src, el.alt || '');
      });
    });

    lightbox.querySelectorAll('[data-close]').forEach((el) => {
      el.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox.hidden) close();
    });
  }

  document.addEventListener('astro:page-load', setupBlogLightbox);
</script>