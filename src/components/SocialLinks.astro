---
import { Icon } from 'astro-icon/components';
import { SOCIAL_LINKS } from '../consts';

interface Props {
  size?: number;
  class?: string;
}

const { size = 20, class: className = '' } = Astro.props;

const links = [
  { href: SOCIAL_LINKS.github, icon: 'lucide:github', label: 'github' },
  { href: SOCIAL_LINKS.youtube, icon: 'lucide:youtube', label: 'youtube' },
  { href: SOCIAL_LINKS.mastodon, icon: 'lucide:at-sign', label: 'mastodon' },
  { href: SOCIAL_LINKS.discord, icon: 'lucide:message-circle', label: 'discord' },
  { href: SOCIAL_LINKS.bluesky, icon: 'lucide:cloud', label: 'bluesky' },
];
---

<ul class={`social-links ${className}`} aria-label="social links">
  {links.map(({ href, icon, label }) => (
    <li>
      <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
        <Icon name={icon} width={size} height={size} />
      </a>
    </li>
  ))}
</ul>

<style>
  .social-links {
    display: flex;
    gap: 0.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .social-links a {
    color: var(--color-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .social-links a:hover {
    color: var(--color-accent);
    transform: translateY(-1px);
  }
</style>
