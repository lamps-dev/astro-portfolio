# Wakatime API key, kept server-side only.
# Used by src/pages/api/wakatime.ts. Do NOT prefix with PUBLIC_.
# Get yours at https://wakatime.com/settings/api-key
#
# Local dev: copy this file to .env and fill the value in.
# Production (Vercel): set WAKATIME_API_KEY under
#   Project -> Settings -> Environment Variables (or `vercel env add`).
# It is read at request time via process.env in the /api/wakatime route,
# so updates take effect on the next request -- no rebuild needed.
WAKATIME_API_KEY=

# GitHub token, kept server-side only. OPTIONAL.
# Used by src/pages/api/commits.ts to power the /changelog page.
# Unauthenticated requests work too, but GitHub limits them to 60/hour
# per IP; a token raises that to 5000/hour. A classic token needs no
# scopes (public data only), or a fine-grained token with read-only
# public access. Do NOT prefix with PUBLIC_.
# Production (Vercel): set GITHUB_TOKEN under
#   Project -> Settings -> Environment Variables (or `vercel env add`).
GITHUB_TOKEN=
