---
import { Icon } from 'astro-icon/components';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusLabels: Record<Project['status'], string> = {
  active: 'active',
  'random and silly': 'silly projects',
  'old and abandonned, rip': 'rip',
  'semi-active': 'semi-active',
  'no longer active': 'no longer active',
  'wip': 'WIP',
};
---

<article class={`project-card status-${project.status}`}>
  {project.image && (
    <div class="thumb">
      <img src={project.image} alt={`${project.name} screenshot`} loading="lazy" />
    </div>
  )}

  <div class="body">
    <header class="head">
      <h3 class="name">{project.name}</h3>
      <span class="status">{statusLabels[project.status]}</span>
    </header>

    <p class="tagline">{project.tagline}</p>
    <p class="desc">{project.description}</p>

    {project.tech.length > 0 && (
      <ul class="tech" aria-label="tech used">
        {project.tech.map((t) => <li>{t}</li>)}
      </ul>
    )}

    <div class="links">
      {project.github && (
        <a href={project.github} target="_blank" rel="noopener noreferrer" aria-label="github">
          <Icon name="lucide:github" width={16} height={16} /> code
        </a>
      )}
      {project.demo && (
        <a href={project.demo} target="_blank" rel="noopener noreferrer" aria-label="demo">
          <Icon name="lucide:external-link" width={16} height={16} /> live
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    background: color-mix(in oklab, var(--color-bg) 85%, var(--color-border));
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }
  .project-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .status-rip {
    opacity: 0.7;
  }
  .status-rip .name {
    text-decoration: line-through;
    text-decoration-color: var(--color-muted);
  }
  .status-stupid {
    border-style: dashed;
  }
  .thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-border);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .name {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
  }
  .status {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    padding: 2px 6px;
    border-radius: 4px;
    background: color-mix(in oklab, var(--color-border) 70%, transparent);
  }
  .status-active .status {
    color: var(--color-accent);
  }
  .tagline {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }
  .desc {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    color: var(--color-text);
  }
  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
  }
  .tech li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-border) 60%, transparent);
    color: var(--color-muted);
  }
  .links {
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    gap: 1rem;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--color-accent);
  }
  .links a:hover {
    text-decoration: underline;
  }
</style>
